{
  "name": "modding-helper",
  "version": "1.0.0",
  "description": "osu!taiko modding support tool",
  "main": "electron/main.js",
  "repository": "https://github.com/calmeel/modding-helper",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win nsis",
    "publish": "electron-builder --win nsis --publish always"
  },
  "build": {
    "appId": "com.vanity8.modding-helper",
    "productName": "Modding Helper",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "images/icon.ico",
      "artifactName": "ModdingHelper-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "calmeel",
        "repo": "modding-helper"
      }
    ],
    "files": [
      "**/*",
      "!.git/**",
      "!node_modules/.cache/**"
    ],
    "extraFiles": [],
    "directories": {
      "output": "electron/dist"
    }
  },
  "devDependencies": {
    "electron": "^13.4.0",
    "electron-builder": "^25.0.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.35.2"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "jszip": "^3.10.1"
  }
}
